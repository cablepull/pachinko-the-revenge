{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://magnetfragnet.local/schema/v1/evidence.schema.json",
  "title": "ACH analysis — evidence",
  "type": "object",
  "required": ["hypothesisIds", "evidence"],
  "properties": {
    "hypothesisIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "evidenceFamilies": { "type": "object" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "observation", "sourceIds", "reliability", "credibility", "scores"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "observation": { "type": "string", "minLength": 1 },
          "sourceIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "sourceType": { "type": "string" },
          "reliability": {
            "type": "string",
            "enum": ["A", "B", "C", "D", "E", "F"]
          },
          "credibility": { "type": "number", "minimum": 1, "maximum": 6 },
          "provenance": { "type": "string" },
          "timeliness": { "type": "string" },
          "corroboration": { "type": "string" },
          "manipulationRisk": { "type": "string", "enum": ["low", "medium", "high"] },
          "diagnosticity": { "type": "string", "enum": ["low", "medium", "high", "very-high"] },
          "families": { "type": "array", "items": { "type": "string" } },
          "scores": {
            "type": "object",
            "patternProperties": {
              "^.+$": { "type": "number", "minimum": -2, "maximum": 2 }
            }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
