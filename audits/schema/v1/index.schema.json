{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://magnetfragnet.local/schema/v1/index.schema.json",
  "title": "ACH analyses index (cablepull-compatible)",
  "type": "object",
  "required": ["name", "version", "analyses"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "discovery": { "type": "object" },
    "analyses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "title": { "type": "string" },
          "subtitle": { "type": "string" },
          "date": { "type": "string" },
          "analyst": { "type": "string" },
          "evidenceCount": { "type": "number" },
          "hypothesisCount": { "type": "number" },
          "status": { "type": "string" },
          "form": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
