{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://magnetfragnet.local/schema/v1/hypotheses.schema.json",
  "title": "ACH analysis — hypotheses",
  "type": "object",
  "required": ["scoreScale", "confidenceScale", "hypotheses"],
  "properties": {
    "scoreScale": { "type": "object" },
    "confidenceScale": {
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "type": "object",
          "required": ["weight", "label"],
          "properties": {
            "weight": { "type": "number" },
            "label": { "type": "string" }
          }
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "description", "confidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "shortLabel": { "type": "string" },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "assessment": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["low", "moderate", "moderate-to-high", "high", "very-high"]
          },
          "counterevidence": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "lineage": {
            "type": "object",
            "properties": {
              "derivedFrom": {
                "anyOf": [{ "type": "null" }, { "type": "array", "items": { "type": "string" } }]
              },
              "supersededBy": {
                "anyOf": [{ "type": "null" }, { "type": "string" }, { "type": "array", "items": { "type": "string" } }]
              },
              "mergedFrom": {
                "anyOf": [{ "type": "null" }, { "type": "array", "items": { "type": "string" } }]
              }
            }
          }
        }
      }
    }
  }
}
