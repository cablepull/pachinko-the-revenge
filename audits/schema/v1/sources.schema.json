{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://magnetfragnet.local/schema/v1/sources.schema.json",
  "title": "ACH analysis — sources",
  "type": "object",
  "required": ["sources"],
  "properties": {
    "sources": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^.+$": {
          "type": "object",
          "required": ["title", "type", "reliability"],
          "properties": {
            "title": { "type": "string", "minLength": 1 },
            "publisher": { "type": "string" },
            "date": { "type": "string" },
            "url": { "type": "string" },
            "type": {
              "type": "string",
              "description": "magnetfragnet C-12 narrows the type to {test, research, artifact}; the cablepull upstream allows broader values. We validate strict admissibility separately."
            },
            "reliability": {
              "type": "string",
              "enum": ["A", "B", "C", "D", "E", "F"]
            },
            "path": {
              "type": "string",
              "description": "Required for type in {test, research, artifact}. Resolved relative to project root."
            },
            "commit": { "type": "string" },
            "notes": { "type": "string" }
          }
        }
      }
    }
  }
}
